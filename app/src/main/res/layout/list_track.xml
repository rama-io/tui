<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/app_row_header"
    android:paddingStart="16sp"
    android:paddingEnd="16sp"
    android:background="@color/bg_2"
    style="@style/HorizontalListDivided">

    <FrameLayout
        android:id="@+id/disc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">

        <ImageView
            android:src="@drawable/px_disc"
            android:tint="@color/accent_4"
            style="@style/Icon32" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:paddingTop="8sp"
        android:paddingBottom="8sp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/track_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_track_field"
            android:textSize="16sp"
            android:textColor="@color/foreground" />

        <TextView
            android:id="@+id/track_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/placeholder_track_field"
            android:textSize="12sp"
            android:textColor="@color/foreground" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/track_country"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8sp"
                android:text="@string/placeholder_track_field"
                android:textSize="12sp"
                android:textColor="@color/accent_1" />

            <TextView
                android:id="@+id/track_lang"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/placeholder_track_field"
                android:textSize="12sp"
                android:textColor="@color/accent_3" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/track_ext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/placeholder_track_field"
        android:textSize="16sp"
        android:textColor="@color/disabled" />
</LinearLayout>