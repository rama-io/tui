                android:tint="@color/accent_4"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/name_version"
                android:textSize="22sp"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground" />

            <TextView
                android:text="@string/app_desc"
                android:textSize="16sp"
                android:layout_gravity="center"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAlignment="center"
                android:textColor="@color/foreground" />

            <TextView
                android:text="@string/h2_app"
                style="@style/H3" />

            <com.rama.bohio.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/px_user"
                android:text="@string/app_creator" />

            <com.rama.bohio.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/px_seedlings"
                android:text="@string/app_name" />

            <com.rama.bohio.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/px_github"
                android:text="@string/product_tui_url" />

            <com.rama.bohio.widgets.WdLabel
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:icon="@drawable/px_octagon_check"
                android:text="@string/app_ads_desc" />

            <!--            <com.rama.bohio.widgets.WdLabel-->
