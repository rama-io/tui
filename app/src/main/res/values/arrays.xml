<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Single source of truth for supported languages.
         To add a new language:
         1. Add a values-xx/strings.xml with translations
         2. Add the language code below
         3. Add a label entry (use @string or a literal like "Türkçe") -->
    <string-array name="supported_language_codes">
        <item>system</item>
        <item>en</item>
    </string-array>

    <string-array name="supported_language_labels">
        <item>@string/radio_language_system_default</item>
        <item>@string/radio_language_english</item>
    </string-array>

    <string-array name="supported_audio_formats">
        <item>mp3</item>
        <item>m4a</item>
        <item>aac</item>
        <item>flac</item>
        <item>ogg</item>
        <item>wav</item>
        <item>aiff</item>
        <item>wma</item>
        <item>alac</item>
        <item>ape</item>
        <item>wv</item>
        <item>tta</item>
        <item>dsf</item>
        <item>dff</item>
        <item>opus</item>
        <item>amr</item>
        <item>mka</item>
    </string-array>

</resources>
